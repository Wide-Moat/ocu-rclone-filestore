# EditorConfig is awesome: https://editorconfig.org
# Top-most EditorConfig file.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4

[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

[{Makefile,makefile,GNUmakefile,*.mk}]
indent_style = tab
