#
# Package map: what is inside the repo and who calls whom.
# Render: d2 docs/diagrams/03-package-map.d2 docs/diagrams/03-package-map.svg

direction: down

title: |md
  # What is inside — the packages and how they connect
| {near: top-center; style.font-size: 28}

cmd: "cmd/ocu-rclone-filestore\nthe entrypoint: parse flags, load config,\nclaim signals, drive the mounter, set exit code" {
  style: {fill: "#e8eaff"; stroke: "#5b3bcf"; stroke-width: 2; border-radius: 10; font-color: "#000"}
}

mountcfg: "internal/mountcfg\nstrictly decode the mount config;\nrefuse any credential marker" {
  style: {fill: "#eef3ff"; stroke: "#3b5bcf"; border-radius: 10; font-color: "#000"}
}
contract: "internal/contract\nvalidate config against the\nguest subschema (test-time gate)" {
  style: {fill: "#f0f0f0"; stroke: "#888"; border-radius: 10; font-color: "#000"}
}

mounter: "internal/mounter\nbring up N mounts: fail fast, map\noptions, mount over /dev/fuse, tear down" {
  style: {fill: "#eef3ff"; stroke: "#3b5bcf"; border-radius: 10; font-color: "#000"}
}

ocufs: "backend/ocufs\nthe rclone backend: map file ops\nto broker calls; read-only gate" {
  style: {fill: "#eafaef"; stroke: "#2e9e54"; stroke-width: 2; border-radius: 10; font-color: "#000"}
}

brokerrpc: "internal/brokerrpc\nthe ONLY way out: Connect-RPC client\nover the per-session unix socket" {
  style: {fill: "#fff1f0"; stroke: "#cf3b3b"; stroke-width: 3; border-radius: 10; bold: true; font-color: "#000"}
}

socket: "broker unix socket" {shape: cylinder; style: {fill: "#ffe9b3"; stroke: "#d4a017"; font-color: "#000"}}

cmd -> mountcfg: "loads + validates"
cmd -> mounter: "drives"
mountcfg -> contract: "shape pinned by" {style.stroke-dash: 4; style.stroke: "#888"}
mounter -> ocufs: "builds an Fs per mount"
ocufs -> brokerrpc: "every op goes through here"
brokerrpc -> socket: "dials" {style: {stroke: "#cf3b3b"; stroke-width: 3}}

guards: "Guard packages (tests only — never in the binary):\ninternal/buildgraph asserts no object-store SDK is linked  •  internal/coverage enforces the coverage floor" {
  style: {fill: "#f7f7f7"; stroke: "#bbb"; font-size: 12; font-color: "#555"}
}

legend: |md
  **Reading order:** entrypoint → config → mounter → backend → the single socket.
  Green = the rclone backend. Red = the one egress. Grey = test-time guards, not shipped.
| {near: bottom-center; style: {fill: "#fafafa"; stroke: "#bbb"; font-size: 13}}
